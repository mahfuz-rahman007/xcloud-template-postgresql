{
  "schema_version": "1.0",
  "slug": "postgresql",
  "name": "PostgreSQL",
  "description": "Advanced open-source relational database. The world's most advanced open source database.",
  "version": "1.0.0",
  "app_version": "17",
  "icon": "assets/icon.png",
  "category": "database",
  "service_class": "data_service",
  "tags": ["database", "sql", "relational", "postgres"],
  "website": "https://postgresql.org",

  "requirements": {
    "min_ram_mb": 512,
    "min_cpu_cores": 1,
    "min_disk_gb": 2,
    "stack": ["docker_nginx"],
    "singleton": false
  },

  "ports": {
    "postgres": {
      "description": "PostgreSQL connection",
      "container_port": 5432,
      "protocol": "tcp",
      "proxy": false,
      "visibility": "private"
    }
  },

  "fields": [
    {
      "key": "admin_user",
      "label": "Superuser Username",
      "type": "text",
      "required": true,
      "default": "postgres",
      "validation": "string|max:32|alpha_dash",
      "group": "credentials"
    },
    {
      "key": "admin_password",
      "label": "Superuser Password",
      "type": "password",
      "required": true,
      "validation": "string|min:8|max:64",
      "generate": true,
      "generate_length": 24,
      "group": "credentials"
    },
    {
      "key": "database_name",
      "label": "Default Database",
      "type": "text",
      "required": true,
      "default": "default_db",
      "validation": "string|max:63|alpha_dash",
      "group": "credentials"
    }
  ],

  "field_groups": [
    { "key": "credentials", "label": "Connection Credentials", "icon": "xcloud xc-key" }
  ],

  "environment_map": {
    "POSTGRES_USER": "{{ admin_user }}",
    "POSTGRES_DB": "{{ database_name }}"
  },

  "secrets": {
    "POSTGRES_PASSWORD": "{{ admin_password }}"
  },

  "generated_values": {},

  "credentials": {
    "type": "connection_string",
    "template": "postgresql://{{ admin_user }}:{{ admin_password }}@{{ server_ip }}:{{ ports.postgres }}/{{ database_name }}",
    "display": [
      { "label": "Host", "value": "{{ server_ip }}" },
      { "label": "Port", "value": "{{ ports.postgres }}" },
      { "label": "Database", "value": "{{ database_name }}" },
      { "label": "Username", "value": "{{ admin_user }}" },
      { "label": "Password", "value": "{{ admin_password }}", "secret": true }
    ],
    "copyable": "postgresql://{{ admin_user }}:{{ admin_password }}@{{ server_ip }}:{{ ports.postgres }}/{{ database_name }}"
  },

  "health_check": {
    "type": "tcp",
    "port": "postgres",
    "timeout_seconds": 60
  },

  "backup": {
    "strategy": "dump",
    "dump_command": "docker exec {{ containers.postgres }} pg_dumpall -U {{ admin_user }}",
    "restore_command": "docker exec -i {{ containers.postgres }} psql -U {{ admin_user }}",
    "backup_extension": ".sql"
  },

  "network": {
    "default_visibility": "private",
    "allow_external_access": true,
    "external_access_requires_confirmation": true,
    "ip_whitelist_support": true,
    "firewall_rules": [
      { "port": "postgres", "allow_from": "server_only" }
    ]
  },

  "volumes": {
    "persistent": ["pgdata"]
  },

  "post_install": {
    "message": "PostgreSQL is running. Connection details are shown below. By default, it is only accessible from this server."
  },

  "release_channel": "stable",

  "upgrade": {
    "strategy": "rolling",
    "backup_volumes": true,
    "breaking_versions": [
      {
        "from": "<17",
        "to": ">=17",
        "warning": "Major version upgrade requires pg_upgrade. Back up your data first."
      }
    ]
  }
}
